    def get_all_compartments(self):
        """Get all compartments."""
        if self.compartments_cache:
            return self.compartments_cache
        
        print("\n📋 Fetching compartments...")
        compartments = []
        
        try:
            compartments.append({
                'id': self.tenancy_id,
                'name': self.tenancy.name
            })
            
            response = oci.pagination.list_call_get_all_results(
                self.identity.list_compartments,
                self.tenancy_id,
                compartment_id_in_subtree=True,
                access_level="ACCESSIBLE"
            )
            
            for comp in response.data:
                if comp.lifecycle_state == 'ACTIVE':
                    compartments.append({
                        'id': comp.id,
                        'name': comp.name
                    })
            
            self.compartments_cache = compartments
            print(f"✅ Found {len(compartments)} active compartments")
            return compartments
            
        except Exception as e:
            print(f"⚠️  Error fetching compartments: {e}")
            return [{'id': self.tenancy_id, 'name': self.tenancy.name}]
    
    def add_resource(self, resources, name, ocid, compartment, state='ACTIVE', **kwargs):
        """Helper to add resource with standard fields."""
        resource = {
            'Name': name,
            'OCID': ocid,
            'Compartment': compartment,
            'State': state,
            'Region': self.region
        }
        resource.update(kwargs)
        resources.append(resource)
    
