            ('Boot Volume', self.get_boot_volumes),
            ('Volume Backup', self.get_volume_backups),
            ('Boot Volume Backup', self.get_boot_volume_backups),
            ('Volume Backup Policy', self.get_volume_backup_policies),
            ('Object Storage Bucket', self.get_object_storage_buckets),
            ('File Storage', self.get_file_storage),
            
            # NETWORKING - CORE
            ('VCN', self.get_vcns),
            ('Subnet', self.get_subnets),
            ('Dynamic Routing Gateway', self.get_drgs),
            
            # NETWORKING - SECURITY
            ('Network Security Group', self.get_network_security_groups),
            ('Security List', self.get_security_lists),
            ('Route Table', self.get_route_tables),
            
            # NETWORKING - GATEWAYS
            ('Internet Gateway', self.get_internet_gateways),
            ('NAT Gateway', self.get_nat_gateways),
            ('Service Gateway', self.get_service_gateways),
            ('Local Peering Gateway', self.get_local_peering_gateways),
            
            # NETWORKING - CONNECTIVITY
            ('IPSec VPN Connection', self.get_ipsec_connections),
            ('Customer Premise Equipment', self.get_cpes),
            ('Public IP', self.get_public_ips),
            
            # LOAD BALANCERS
            ('Load Balancer', self.get_load_balancers),
            
            # SECURITY
            ('Network Firewall', self.get_network_firewalls),
            ('WAF Policy', self.get_waf_policies),
            ('Vault', self.get_vaults),
            ('Bastion', self.get_bastions),
            
            # DATABASES
            ('Autonomous Database', self.get_autonomous_databases),
            ('DB System', self.get_db_systems),
            ('Exadata Infrastructure', self.get_exadata_infrastructures),
            ('MySQL Database', self.get_mysql_databases),
            ('NoSQL Table', self.get_nosql_tables),
            
            # CONTAINERS
            ('OKE Cluster', self.get_oke_clusters),
            ('Container Instance', self.get_container_instances),
            
            # VMWARE
            ('VMware SDDC', self.get_vmware_sddcs),
            
            # DEVELOPER SERVICES
            ('Functions Application', self.get_functions_applications),
            ('API Gateway', self.get_api_gateways),
            ('Streaming Stream', self.get_streaming_streams),
            ('Events Rule', self.get_events_rules),
            
            # ANALYTICS & BIG DATA
            ('Analytics Instance', self.get_analytics_instances),
            ('Data Science Project', self.get_data_science_projects),
            ('Data Flow Application', self.get_data_flow_applications),
            ('Big Data Cluster', self.get_big_data_clusters),
            
            # INTEGRATION
            ('Integration Instance', self.get_integration_instances),
            ('Service Connector', self.get_service_connectors),
            ('GoldenGate Deployment', self.get_golden_gate_deployments),
            
            # MONITORING & NOTIFICATIONS
            ('Monitoring Alarm', self.get_alarms),
            ('Log Group', self.get_log_groups),
            ('Notification Topic', self.get_notification_topics),
            ('Email Sender', self.get_email_senders),
            
            # DNS & HEALTH
            ('DNS Zone', self.get_dns_zones),
            ('Health Check', self.get_health_checks),
            
            # AI/ML
            ('Digital Assistant', self.get_digital_assistants),
        ]
        
        for res_type, getter_func in resource_types:
            try:
                resources = getter_func(comp)
                for res in resources:
                    res['Resource Type'] = res_type
                    all_res.append(res)
            except:
                pass
        
        return all_res
    
    def run_inventory(self):
        """Run complete inventory with parallel processing."""
        print("\n" + "=" * 80)
        print("  Starting ULTIMATE Resource Inventory Scan (50+ Services)")
        print("=" * 80)
        
        compartments = self.get_all_compartments()
        total_comps = len(compartments)
        
        print(f"\n🚀 Scanning {total_comps} compartments in parallel...")
        print(f"   Max parallel workers: {MAX_WORKERS}")
        print(f"   Progress updates every 10 compartments\n")
        
        processed = 0
        
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
            future_to_comp = {
                executor.submit(self.scan_compartment, comp): comp 
                for comp in compartments
            }
            
            for future in as_completed(future_to_comp):
                try:
                    resources = future.result()
                    self.all_resources.extend(resources)
                    
                    for res in resources:
                        self.resource_counts[res['Resource Type']] += 1
                    
                    processed += 1
                    
                    if processed % 10 == 0 or processed == total_comps:
                        elapsed = time.time() - self.start_time
                        print(f"   [{processed}/{total_comps}] Processed | "
                              f"Total resources: {len(self.all_resources)} | "
                              f"Elapsed: {int(elapsed)}s")
                except:
                    processed += 1
        
        elapsed_time = time.time() - self.start_time
        
        print("\n" + "=" * 80)
        print(f"  ✅ Scan Complete! Found {len(self.all_resources)} total resources")
        print(f"  📊 Resource types found: {len(self.resource_counts)}")
        print(f"  ⏱️  Time elapsed: {int(elapsed_time)} seconds ({elapsed_time/60:.1f} minutes)")
        print("=" * 80)
    
    def export_to_excel(self):
        """Export to Excel."""
        print("\n📊 Exporting to Excel...")
        
        wb = Workbook()
        if 'Sheet' in wb.sheetnames:
            wb.remove(wb['Sheet'])
        
        # Summary sheet
        ws = wb.create_sheet("Summary", 0)
        ws['A1'] = "OCI ULTIMATE COMPLETE INVENTORY - ALL SERVICES"
        ws['A1'].font = Font(bold=True, size=16, color="FFFFFF")
        ws['A1'].fill = PatternFill(start_color="2E75B6", end_color="2E75B6", fill_type="solid")
        ws['A1'].alignment = Alignment(horizontal='center')
        ws.merge_cells('A1:D1')
        
        row = 3
        metadata = [
            ("Tenancy:", self.tenancy.name),
            ("Region:", self.region),
            ("Scan Date:", datetime.now().strftime('%Y-%m-%d %H:%M:%S')),
            ("Total Resources:", len(self.all_resources)),
            ("Resource Types:", len(self.resource_counts)),
            ("Compartments:", len(self.compartments_cache))
        ]
        
        for label, value in metadata:
            ws[f'A{row}'] = label
            ws[f'B{row}'] = value
            ws[f'A{row}'].font = Font(bold=True)
            if label == "Total Resources:":
                ws[f'B{row}'].font = Font(bold=True, color="2E75B6", size=12)
            row += 1
        
        # Resource counts table
        row += 2
        ws[f'A{row}'] = "Resource Type"
        ws[f'B{row}'] = "Count"
        for col in ['A', 'B']:
            ws[f'{col}{row}'].font = Font(bold=True, color="FFFFFF")
            ws[f'{col}{row}'].fill = PatternFill(start_color="2E75B6", end_color="2E75B6", fill_type="solid")
        
        for res_type, count in sorted(self.resource_counts.items(), key=lambda x: x[1], reverse=True):
            row += 1
            ws[f'A{row}'] = res_type
            ws[f'B{row}'] = count
        
        ws.column_dimensions['A'].width = 40
        ws.column_dimensions['B'].width = 15
        
        # All Resources sheet
        if self.all_resources:
            ws = wb.create_sheet("All Resources")
            headers = list(self.all_resources[0].keys())
            
            for col_num, header in enumerate(headers, 1):
                cell = ws.cell(row=1, column=col_num)
                cell.value = header
                cell.font = Font(bold=True, color="FFFFFF")
                cell.fill = PatternFill(start_color="2E75B6", end_color="2E75B6", fill_type="solid")
                cell.alignment = Alignment(horizontal='center')
            
            for row_num, resource in enumerate(self.all_resources, 2):
                for col_num, header in enumerate(headers, 1):
                    ws.cell(row=row_num, column=col_num, value=resource.get(header, ''))
            
            for col in range(1, len(headers) + 1):
                ws.column_dimensions[get_column_letter(col)].width = 20
        
        # Individual type sheets
        for res_type in sorted(self.resource_counts.keys()):
            type_resources = [r for r in self.all_resources if r['Resource Type'] == res_type]
            if not type_resources:
                continue
            
            sheet_name = res_type[:31]
            ws = wb.create_sheet(sheet_name)
            
            headers = list(type_resources[0].keys())
            for col_num, header in enumerate(headers, 1):
                cell = ws.cell(row=1, column=col_num)
                cell.value = header
                cell.font = Font(bold=True, color="FFFFFF")
                cell.fill = PatternFill(start_color="2E75B6", end_color="2E75B6", fill_type="solid")
                cell.alignment = Alignment(horizontal='center')
            
            for row_num, resource in enumerate(type_resources, 2):
                for col_num, header in enumerate(headers, 1):
                    ws.cell(row=row_num, column=col_num, value=resource.get(header, ''))
            
            for col in range(1, len(headers) + 1):
                ws.column_dimensions[get_column_letter(col)].width = 20
        
        wb.save(OUTPUT_FILE)
        print(f"✅ Excel file saved: {OUTPUT_FILE}")
        print(f"   Total resources: {len(self.all_resources)}")
        print(f"   Resource types: {len(self.resource_counts)}")
        print(f"   Total sheets: {len(wb.sheetnames)}")

